# Copy to .env and customize. Never commit .env.

# Admin usernames (comma-separated). Auto-approved on signup and can manage
# other users at /hub/authorize.
JUPYTERHUB_ADMIN_USERS=admin

# Port to expose the Hub on the host. If you put Caddy/nginx in front for
# HTTPS, also change docker-compose.yml's ports line to bind to 127.0.0.1.
HUB_PORT=8000

# Image to spawn for each logged-in user. Defaults to the published GHCR
# image. For local testing change to e.g. cesm-lab-neon-custom:dev.
DOCKER_SPAWN_IMAGE=ghcr.io/mariaob1201/ncar-nsf-neon:latest

# Per-user resource limits enforced by Docker
JUPYTERHUB_MEM_LIMIT=4G
JUPYTERHUB_CPU_LIMIT=2
